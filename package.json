{
  "name": "@zepdev/design-system-zhd-react",
  "version": "1.17.3",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/zepdev"
  },
  "engines": {
    "npm": ">=10.1.0",
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "run-p build:*",
    "build:css": "tailwindcss -m -i ./src/tailwind.css -o ./dist/styles.css",
    "build:scripts": "vite build",
    "build:types": "tsc --p ./tsconfig.build.json",
    "preview": "vite preview",
    "storybook": "storybook dev -p 9008",
    "build-storybook": "storybook build",
    "build-storybook:develop": "cross-env NODE_ENV=development storybook build",
    "test-storybook": "test-storybook --url http://127.0.0.1:9008",
    "test": "vitest",
    "semantic-release": "semantic-release",
    "lint": "eslint --max-warnings=0 src",
    "prettier": "npx prettier --write .",
    "prepare": "install-peers",
    "chromatic": "chromatic --only-changed --exit-once-uploaded",
    "tailwind-config-viewer": "tailwind-config-viewer -c tailwind.config.cjs -o"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs.js",
      "import": "./dist/index.es.js",
      "types": "./dist/lib/index.d.ts"
    },
    "./dist/styles.css": "./dist/styles.css",
    "./tailwind.config": "./tailwind.config.cjs"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "tailwind.config.cjs"
  ],
  "dependencies": {
    "@headlessui/react": "^1.7.17",
